generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  password             String
  role                 Role             @default(CLIENT)
  isActive             Boolean          @default(true)
  refreshToken         String?
  avatar               String?
  phone                String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  client               Client?
  editor               Editor?
  notifications        Notification[]
  projectComments      ProjectComment[]
  connectedForms       ConnectedForm[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Client {
  id          String    @id @default(cuid())
  userId      String    @unique
  company     String?
  phone       String?
  address     String?
  city        String?
  country     String?
  notes       String?
  advancePaid Decimal?  @db.Decimal(10, 2)
  currency    String    @default("USD")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  projects    Project[]

  @@index([userId])
  @@map("clients")
}

model Editor {
  id           String    @id @default(cuid())
  userId       String    @unique
  bio          String?
  skills       String[]
  hourlyRate   Decimal?  @db.Decimal(10, 2)
  availability Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@index([userId])
  @@map("editors")
}

model Project {
  id                  String           @id @default(cuid())
  title               String
  description         String?
  status              ProjectStatus    @default(NEW_VIDEO)
  priority            Priority         @default(MEDIUM)
  clientId            String
  editorId            String?
  dueDate             DateTime?
  submissionDate      DateTime?
  budget              Decimal?         @db.Decimal(10, 2)
  clientPrice         Decimal?         @db.Decimal(10, 2)
  editorPrice         Decimal?         @db.Decimal(10, 2)
  tags                String[]
  notes               String?
  driveFolder         String?
  formLink            String?
  rawMaterialsFolder  String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  invoices            Invoice[]
  invoicedProjects    Invoice[]        @relation("InvoiceProjects")
  notifications       Notification[]
  files               ProjectFile[]
  comments            ProjectComment[]
  client              Client           @relation(fields: [clientId], references: [id])
  editor              Editor?          @relation(fields: [editorId], references: [id])

  @@index([clientId])
  @@index([editorId])
  @@index([status])
  @@index([priority])
  @@map("projects")
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@map("project_comments")
}

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  uploadedById String
  filename     String
  originalName String
  url          String
  mimeType     String?
  fileType     FileType @default(OTHER)
  size         Int?
  driveFileId  String?
  description  String?
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_files")
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique
  projectId  String?
  clientId   String
  status     InvoiceStatus @default(DRAFT)
  items      Json
  subtotal   Decimal       @db.Decimal(10, 2)
  taxRate    Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount  Decimal       @default(0) @db.Decimal(10, 2)
  discount   Decimal       @default(0) @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  amountPaid Decimal       @default(0) @db.Decimal(10, 2)
  dueDate    DateTime?
  sentAt     DateTime?
  paidAt     DateTime?
  notes      String?
  terms      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  client     Client        @relation(fields: [clientId], references: [id])
  project    Project?      @relation(fields: [projectId], references: [id])
  projects   Project[]     @relation("InvoiceProjects")
  payments   Payment[]

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(PENDING)
  transactionId String?
  reference     String?
  notes         String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  projectId String?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  project   Project?         @relation(fields: [projectId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model EditorAssignmentLog {
  id               String   @id @default(cuid())
  projectId        String
  previousEditorId String?
  newEditorId      String?
  changedById      String
  createdAt        DateTime @default(now())

  @@index([projectId])
  @@index([changedById])
  @@map("editor_assignment_logs")
}

enum Role {
  ADMIN
  EDITOR
  CLIENT
}

enum ProjectStatus {
  NEW_VIDEO
  EDITING
  EDITING_REVIEW
  REVISION_1
  REVISION_1_REVIEW
  REVISION_2
  REVISION_2_REVIEW
  FINAL_DRAFT
  UPLOADED
  CANCELLED
  ON_HOLD
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  UPI
  PAYPAL
  STRIPE
  CASH
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  PROJECT_ASSIGNED
  PROJECT_STATUS_CHANGED
  INVOICE_CREATED
  INVOICE_PAID
  INVOICE_OVERDUE
  PAYMENT_RECEIVED
  FILE_UPLOADED
  COMMENT_ADDED
  DEADLINE_REMINDER
  GENERAL
  PROJECT_UNASSIGNED
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  ARCHIVE
  OTHER
}

enum FormSyncStatus {
  ACTIVE
  WATCH_EXPIRING
  WATCH_EXPIRED
  ERROR
}

enum MattworkFormField {
  CLIENT_NAME
  VIDEO_TITLE
  PROJECT_TYPE
  ASSIGNED_DATE
  DEADLINE_DATE
  MATERIALS_LINK
}

model ConnectedForm {
  id                             String                  @id @default(cuid())
  googleFormId                   String                  @unique
  formTitle                      String
  connectedByAdminId             String
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
  lastSyncedAt                   DateTime?
  lastProcessedResponseTimestamp DateTime?
  syncStatus                     FormSyncStatus          @default(ACTIVE)
  connectedByAdmin               User                    @relation(fields: [connectedByAdminId], references: [id])
  mappings                       FormFieldMapping[]
  watches                        FormWatch[]
  processedResponses             ProcessedFormResponse[]

  @@index([googleFormId])
  @@index([connectedByAdminId])
  @@map("connected_forms")
}

model FormFieldMapping {
  id                 String            @id @default(cuid())
  connectedFormId    String
  mattworkField      MattworkFormField
  googleQuestionId   String
  googleQuestionType String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  connectedForm      ConnectedForm     @relation(fields: [connectedFormId], references: [id], onDelete: Cascade)

  @@unique([connectedFormId, mattworkField])
  @@index([connectedFormId])
  @@map("form_field_mappings")
}

model FormWatch {
  id              String        @id @default(cuid())
  connectedFormId String
  watchId         String        @unique
  expireTime      DateTime
  pubsubTopic     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  connectedForm   ConnectedForm @relation(fields: [connectedFormId], references: [id], onDelete: Cascade)

  @@index([connectedFormId])
  @@index([watchId])
  @@index([expireTime])
  @@map("form_watches")
}

model ProcessedFormResponse {
  id               String        @id @default(cuid())
  connectedFormId  String
  googleResponseId String
  processedAt      DateTime      @default(now())
  projectId        String?       // ID of the Mattwork project created for this response
  connectedForm    ConnectedForm @relation(fields: [connectedFormId], references: [id], onDelete: Cascade)

  @@unique([connectedFormId, googleResponseId])
  @@index([connectedFormId])
  @@map("processed_form_responses")
}
